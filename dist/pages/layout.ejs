<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | SwiftHost</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/lucide@latest"></script>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');
    body { font-family: 'Inter', sans-serif; background: #0f172a; color: #e2e8f0; }
    .glass { background: rgba(30, 41, 59, 0.7); backdrop-filter: blur(10px); border: 1px solid rgba(255,255,255,0.1); }
    .gradient-text { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .tunnel-card { transition: all 0.3s ease; }
    .tunnel-card:hover { transform: translateY(-2px); box-shadow: 0 10px 40px -10px rgba(102, 126, 234, 0.3); }
  </style>
</head>
<body class="min-h-screen">
  <nav class="glass fixed w-full z-50 border-b border-slate-700">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">
        <div class="flex items-center gap-3">
          <i data-lucide="zap" class="w-8 h-8 text-indigo-400"></i>
          <span class="text-xl font-bold gradient-text">SwiftHost</span>
        </div>
        <div class="flex gap-4">
          <a href="/" class="text-slate-300 hover:text-white px-3 py-2 rounded-md text-sm font-medium">Dashboard</a>
          <a href="/analytics" class="text-slate-300 hover:text-white px-3 py-2 rounded-md text-sm font-medium">Analytics</a>
        </div>
      </div>
    </div>
  </nav>

  <main class="pt-20 pb-12 px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto">
    <%- body %>
  </main>

  <script>lucide.createIcons();</script>
</body>
</html>
